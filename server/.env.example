# --- Server ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# --- JWT Authentication ---
JWT_SECRET=<replace-with-a-long-random-secret>

# --- SMTP / Nodemailer ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password-or-app-password>
SMTP_FROM="Rolling Commerce <noreply@rolling-commerce.com>"

# --- Cloudinary ---
# Keep these only in the backend environment. Never expose API_SECRET to the frontend.
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# --- MercadoPago (Future Payment Integration) ---
MERCADO_PAGO_PUBLIC_KEY=<public-key>
MERCADO_PAGO_ACCESS_TOKEN=<access-token>
