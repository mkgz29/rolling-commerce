# --- Server ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb+srv://<db-user>:<db-password>@<cluster-url>/<database>?retryWrites=true&w=majority

# --- JWT Authentication ---
JWT_SECRET=replace_with_strong_secret

# --- SMTP / Nodemailer utility ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<smtp-user@example.com>
SMTP_PASS=<smtp-password-or-app-password>
SMTP_FROM="Rolling Commerce <noreply@rolling-commerce.com>"

# --- Email service ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<email-user@example.com>
EMAIL_PASSWORD=<email-password-or-app-password>
EMAIL_FROM="Rolling Commerce <noreply@rolling-commerce.com>"
EMAIL_ADDRESS=<test-recipient@example.com>

# --- Cloudinary ---
# Backend only. Never expose CLOUDINARY_API_SECRET to the frontend.
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# --- Mercado Pago ---
# Backend only. Never expose this token to the frontend.
MERCADOPAGO_ACCESS_TOKEN=<mercadopago-access-token>

# --- Client reference ---
# This belongs in client/.env if you need to override the frontend API URL.
VITE_API_URL=http://localhost:3000/api
